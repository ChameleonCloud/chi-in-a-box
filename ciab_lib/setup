setup_venv() {
	local venv_path="${VIRTUAL_ENV:-"${CIAB_DIR}"/"venv"}"
	VIRTUAL_ENV=$(realpath "${venv_path}")

	if [[ ! -d ${VIRTUAL_ENV} ]]; then
		echo "Creating virtualenv at ${VIRTUAL_ENV} ..."
		python3 -m venv "${VIRTUAL_ENV}"
	fi

	# Set venv paths for later commands
	export VIRTUAL_ENV
	export VIRTUAL_ENV="${VIRTUAL_ENV}"
	export PATH="${VIRTUAL_ENV}/bin:${PATH}"

	# Ensure latest version of pip
	pip install --upgrade pip
}

update_python_packages() {
	# Update base pip packages
	pip_requirements="${CIAB_DIR}/requirements.txt"
	pip_requirements_chksum="${VIRTUAL_ENV}/requirements.txt.sha256"
	if [[ ${FORCE_UPDATES} == "yes" || ! -f ${pip_requirements_chksum} ]] ||
		! sha256sum --quiet --check "${pip_requirements_chksum}"; then
		pip install --upgrade --force-reinstall -r "${pip_requirements}"
		sha256sum "${pip_requirements}" >"${pip_requirements_chksum}"
	fi
}

update_ansible_galaxy() {
	# Update Ansible Galaxy roles
	galaxy_role_path="${CIAB_DIR}/roles/galaxy.ansible.com"
	galaxy_role_requirements="${CIAB_DIR}/requirements.yml"
	galaxy_role_requirements_chksum="${VIRTUAL_ENV}/requirements.yml.sha256"
	if [[ ${FORCE_UPDATES} == "yes" || ! -f ${galaxy_role_requirements_chksum} ]] ||
		! sha256sum --quiet --check "${galaxy_role_requirements_chksum}"; then
		ansible-galaxy role install --force -p "${galaxy_role_path}" -r "${galaxy_role_requirements}"
		sha256sum "${galaxy_role_requirements}" >"${galaxy_role_requirements_chksum}"
	fi

}

update_kolla_ansible() {
	local kolla_ansible_remote=https://github.com/ChameleonCloud/kolla-ansible.git
	local kolla_ansible_checkout="${KOLLA_ANSIBLE_BRANCH:-chameleoncloud/xena}"
	local kolla_ansible_gitref="${VIRTUAL_ENV}/kolla-ansible.gitref"
	local kolla_ansible_egglink="${VIRTUAL_ENV}/src/kolla-ansible"

	detect_gitref_change() {
		set -x

		pushd "${kolla_ansible_egglink}"
		git fetch
		current_kolla_ansible_gitref_value=$(git show-ref -s -d origin/"${kolla_ansible_checkout}")
		popd

		kolla_ansible_gitref_value=$(cat "${kolla_ansible_gitref}")

		if [[ ${kolla_ansible_gitref_value} == "${current_kolla_ansible_gitref_value}" ]]; then
			return 0
		else
			return 1
		fi

		set +x
	}
	gitref_changed=detect_gitref_change

	if [[ ${FORCE_UPDATES} == "yes" || ! -f ${kolla_ansible_gitref} || ! -d ${kolla_ansible_egglink} || -z ${gitref_changed} ]]; then
		pushd "${VIRTUAL_ENV}" || (echo "pushd error!" && exit 1)
		python3 -m pip install -e "git+${kolla_ansible_remote}@${kolla_ansible_checkout}#egg=kolla-ansible"
		popd || (echo "popd error!" && exit 1)
		# [jca 2020-01-30] TODO:
		# Ensure the /share folder is placed; this is not copied when using the "develop" setup.py method.
		# This is a bit weird, perhaps there is some way to pass an additional flag to pip to make it
		# copy this even though it's installing as source. We use source install to keep track of the Git revision.
		mkdir -p "${VIRTUAL_ENV}/share" && ln -sf "${kolla_ansible_egglink}" "${VIRTUAL_ENV}/share/kolla-ansible"
		(
			cd "${kolla_ansible_egglink}"
			git rev-parse HEAD >"${kolla_ansible_gitref}"
		)
	fi
}

update_yq() {
	# Update/install yq
	YQ_VERSION=4.9.6
	if [[ "$(type -t yq)" != "file" ]]; then
		YQ_BINARY="yq_linux_amd64"
		wget https://github.com/mikefarah/yq/releases/download/v"${YQ_VERSION}"/"${YQ_BINARY}".tar.gz -O - |
			tar xz && mv "${YQ_BINARY}" "${VIRTUAL_ENV}/bin/yq"
	fi

}
